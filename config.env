# 内核源码 AOSP 通用 GKI 6.6 安卓15
KERNEL_SOURCE=https://android.googlesource.com/kernel/common
KERNEL_SOURCE_BRANCH=android15-6.6

# x86_64 模拟器标准配置
KERNEL_CONFIG=x86_64_ranchu_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=x86_64

# KernelSU 相关
KERNELSU_REPO=tiann/KernelSU
KERNELSU_BRANCH=main

# 编译工具链
USE_CUSTOM_CLANG=false
EXTRA_CMDS=LD=ld.lld
CUSTOM_CMDS:CLANG_TRIPLE=x86_64-linux-gnu-

# 输出命名开关
ADD_LOCALVERSION_TO_FILENAME=false
